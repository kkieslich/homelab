# Template for the BeerBot secret. The REAL file is delivered by sops-nix (in the
# home-infrastructure repo) to /run/secrets/beerbot.env — it is NEVER committed
# here. These are the keys the containers read via env_file. Non-secret,
# host-specific URLs are hardcoded in docker-compose.yml instead, so only true
# secrets + the post-provision Logto app IDs live here.
#
# NOTE the connection strings must point at the in-stack service names
# (beerbot-db), not localhost.

# --- Postgres ---
POSTGRES_PASSWORD=change-me-strong
# .NET App API reads ConnectionStrings__beerbotData; Admin/migrator read BEERBOT_DATA_CONNECTION.
ConnectionStrings__beerbotData=User Id=beerbot;server=beerbot-db;port=5432;database=beerbot;password=change-me-strong
BEERBOT_DATA_CONNECTION=User Id=beerbot;server=beerbot-db;port=5432;database=beerbot;password=change-me-strong
# Logto's own DB connection (Logto reads DB_URL directly).
DB_URL=postgresql://beerbot:change-me-strong@beerbot-db:5432/logto

# --- MinIO ---
MINIO_ROOT_USER=beerbot
MINIO_ROOT_PASSWORD=change-me-strong
MINIO_ACCESS_KEY=beerbot
MINIO_SECRET_KEY=change-me-strong

# --- SMTP (feedback/abuse emails) ---
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# --- Logto management M2M (blank = migrator auto-resolves from the logto DB;
#     LOGTO_DB_CONNECTION is auto-derived from BEERBOT_DATA_CONNECTION) ---------
LOGTO_M2M_SECRET=

# --- Social connectors (provision wires these into Logto; needed for migrated
#     users who signed up with Google/Apple to log in) --------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
# The .p8 contents (use \n for newlines), or deliver the file and set _FILE instead.
APPLE_OAUTH_PRIVATE_KEY=

# --- Logto app IDs — set AFTER the first `provision` run, then restart the web
#     services (they read these at runtime, no rebuild). ------------------------
EXPO_PUBLIC_LOGTO_WEB_APP_ID=
VITE_LOGTO_APP_ID=

# --- Parallel-run migration from OLD prod (beerbot-migrator) ---
# Old prod DBs over the in-service SSH tunnel (localhost:6543 → old-vps:5432).
BEERBOT_LEGACY_CONNECTION=User Id=beerbot;server=localhost;port=6543;database=beerbot;password=OLD-PW
BEERBOT_LEGACY_AUTH_CONNECTION=User Id=beerbot;server=localhost;port=6543;database=auth;password=OLD-PW
# SSH target for the tunnel (user@old-host). The private key is delivered by
# sops-nix to /run/secrets/beerbot-old-vps (mounted at /keys/old-vps).
MIGRATOR_TUNNEL_TARGET=user@old-prod-host
