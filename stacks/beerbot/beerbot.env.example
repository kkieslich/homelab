# Template for the BeerBot secret. The REAL file is delivered by sops-nix (in the
# home-infrastructure repo) to /run/secrets/beerbot.env — it is NEVER committed
# here. These are the keys the containers read via env_file. Non-secret,
# host-specific URLs are hardcoded in docker-compose.yml instead, so only true
# secrets live here.
#
# --- Postgres — SINGLE SOURCE OF TRUTH for the DB cluster ---
# Every .NET consumer builds its connection from these parts via
# PostgresConnection.Build(). No hand-written connection strings to keep in sync.
# POSTGRES_HOST is the in-stack service name (beerbot-db), not localhost.
POSTGRES_USER=beerbot
POSTGRES_PASSWORD=change-me-strong
POSTGRES_HOST=beerbot-db
POSTGRES_DB=beerbot

# --- Keycloak admin bootstrap / migrator access ---
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong

# --- MinIO (one credential pair: server, init job, and .NET clients all use it) ---
# Internal endpoint every .NET service reaches MinIO at (in-stack service name).
# Needed by ALL services that read this env — incl. beerbot-provision, which has
# no inline MinIO config — so it lives here, not only inline in the compose.
MINIO_ENDPOINT=http://beerbot-minio:9000
MINIO_ROOT_USER=beerbot
MINIO_ROOT_PASSWORD=change-me-strong

# --- Social identity providers (provision wires these into Keycloak; needed for migrated
#     users who signed up with Google/Apple to log in) --------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
# Preferred for Komodo/env-file deploys: base64 of the Apple .p8 contents.
APPLE_OAUTH_PRIVATE_KEY_B64=
# Backward-compatible fallback: the .p8 contents with \n escapes.
APPLE_OAUTH_PRIVATE_KEY=

# --- Parallel-run migration from OLD prod (beerbot-migrator) ---
# Old prod DB over the in-service SSH tunnel (localhost:6543 → old-vps:5432). The
# old auth DB is derived from this (db→auth); set BEERBOT_LEGACY_AUTH_CONNECTION
# only to override.
BEERBOT_LEGACY_CONNECTION=User Id=beerbot;server=localhost;port=6543;database=beerbot;password=OLD-PW
# SSH target for the tunnel (user@old-host). The private key is delivered by
# sops-nix to /run/secrets/beerbot-old-vps (mounted at /keys/old-vps).
MIGRATOR_TUNNEL_TARGET=user@old-prod-host
