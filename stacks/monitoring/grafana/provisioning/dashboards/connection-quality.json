      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(speedtest_tracker_download_bits)",
          "legendFormat": "",
          "refId": "A",
          "instant": false,
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 700000000.0
              },
              {
                "color": "green",
                "value": 900000000.0
              }
            ]
          },
          "unit": "bps"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
