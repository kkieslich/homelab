{
  "id": null,
  "uid": "actual-pipeline",
  "title": "Actual — Pipeline",
  "tags": ["actual", "finance", "ops"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "style": "dark",
  "timezone": "",
  "refresh": "1m",
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "links": [
    { "type": "link", "title": "Home",        "url": "/d/actual-home",        "targetBlank": false, "icon": "dashboard", "tags": [] },
    { "type": "link", "title": "Cash Flow",   "url": "/d/actual-cashflow",    "targetBlank": false, "icon": "dashboard", "tags": [] },
    { "type": "link", "title": "Spending",    "url": "/d/actual-spending",    "targetBlank": false, "icon": "dashboard", "tags": [] },
    { "type": "link", "title": "Recurring",   "url": "/d/actual-recurring",   "targetBlank": false, "icon": "dashboard", "tags": [] },
    { "type": "link", "title": "Investments", "url": "/d/actual-investments", "targetBlank": false, "icon": "dashboard", "tags": [] }
  ],
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Per-bank import status (red column = stale)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "actual" },
      "targets": [{
        "refId": "A", "queryType": "table",
        "rawQueryText": "SELECT source AS Bank, last_run_iso AS \"Last run (UTC)\", added AS Added, updated AS Updated, ROUND((strftime('%s','now') - strftime('%s', last_run_iso)) / 3600.0, 2) AS \"Age (hours)\" FROM pipeline_status WHERE source != 'sync' ORDER BY \"Age (hours)\" DESC"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 1 },
        "overrides": [{
          "matcher": { "id": "byName", "options": "Age (hours)" },
          "properties": [{
            "id": "thresholds",
            "value": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "red", "value": 48 }
            ]}
          }, {
            "id": "custom.cellOptions",
            "value": { "type": "color-background" }
          }]
        }]
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "DB sync age",
      "description": "Time since the actual_db_sync container last completed a refresh.",
      "gridPos": { "x": 0, "y": 6, "w": 8, "h": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "actual" },
      "targets": [{
        "refId": "A", "queryType": "table",
        "rawQueryText": "SELECT (strftime('%s', 'now') - strftime('%s', last_run_iso)) AS value FROM pipeline_status WHERE source = 'sync'"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 600 },
            { "color": "red", "value": 1800 }
          ]}
        }
      },
      "options": { "colorMode": "background", "textMode": "value", "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Needs Review",
      "gridPos": { "x": 8, "y": 6, "w": 8, "h": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "actual" },
      "targets": [{
        "refId": "A", "queryType": "table",
        "rawQueryText": "SELECT COUNT(*) AS value FROM transactions WHERE (category_id IS NULL OR category_name = 'Needs Review') AND account_offbudget = 0 AND transfer_id IS NULL"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 20 }
          ]}
        }
      },
      "options": { "colorMode": "background", "textMode": "value", "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Imports last 24h",
      "description": "Transactions whose date is in the last 24 hours. Proxy for daemon activity (most newly-imported txs are dated within a day or two of import).",
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "actual" },
      "targets": [{
        "refId": "A", "queryType": "table",
        "rawQueryText": "SELECT COUNT(*) AS value FROM transactions WHERE date >= date('now', '-1 day') AND account_offbudget = 0"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "value", "textMode": "value", "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Imports per day (last 30 days)",
      "description": "Count of on-budget transactions per day. Reveals the bridge's actual cadence — flat line means nothing got imported, spikes mean a fetch landed.",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "actual" },
      "targets": [{
        "refId": "A", "queryType": "time series",
        "rawQueryText": "SELECT ymd_unix AS time, COUNT(*) AS \"Transactions\" FROM transactions WHERE date >= date('now', '-30 days') AND account_offbudget = 0 GROUP BY ymd_unix ORDER BY ymd_unix",
        "timeColumns": ["time"]
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Recently imported transactions (last 50)",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 12 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "actual" },
      "targets": [{
        "refId": "A", "queryType": "table",
        "rawQueryText": "SELECT date AS Date, account_name AS Account, COALESCE(payee_name, '?') AS Payee, COALESCE(category_name, '(uncategorized)') AS Category, amount_cents / 100.0 AS \"Amount (EUR)\", COALESCE(notes, '') AS Notes FROM transactions ORDER BY date DESC, id DESC LIMIT 50"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyEUR", "decimals": 2 } }
    }
  ]
}
