# Per-bank credentials. The env-var names are referenced from banks.toml.
# Add or remove blocks as you add/remove banks.

BANKS_UMWELT_LOGIN=your-online-banking-username
BANKS_UMWELT_PIN=your-online-banking-pin

BANKS_TRIODOS_LOGIN=your-online-banking-username
BANKS_TRIODOS_PIN=your-online-banking-pin

# Actual Budget server password (set on first login at the actual_server UI).
ACTUAL_PASSWORD=your-actual-password
# Optional, only if you enabled budget encryption:
# ACTUAL_BUDGET_PASSWORD=your-encryption-password
